# DeepSeek API Key (Required for live message refactoring)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API Key (Optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Firebase Web App Credentials (Required for real-time chat sync across clients)
# Create a Realtime Database in your Firebase Console and paste the details below:
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com/
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
